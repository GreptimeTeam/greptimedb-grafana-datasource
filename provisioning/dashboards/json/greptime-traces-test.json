    {
      "title": "Trace Search Table",
      "type": "table",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 10
      },
      "targets": [
        {
          "refId": "A",
          "editorType": "sql",
          "format": 1,
          "queryType": "traces",
          "rawSql": "SELECT trace_id, span_name, service_name, CAST(timestamp AS INT64) / 1000000 AS timestamp_ms, FLOOR(duration_nano * 0.000001) AS duration_ms, span_status_code AS status FROM opentelemetry_traces WHERE $__timeFilter(timestamp) AND \"span_attributes.gen_ai.system\" IS NOT NULL ORDER BY timestamp DESC LIMIT 20",
          "datasource": {
            "type": "info8fcc-greptimedb-datasource",
            "uid": "dfsr7wolp7awwf"
          }
        }
      ],
      "datasource": {
        "type": "info8fcc-greptimedb-datasource",
        "uid": "dfsr7wolp7awwf"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "trace_id"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "View trace",
                    "url": "/d/greptime-traces-test/greptimedb-traces-test?var-trace_id=${__value.raw}&${__url_time_range}",
