    {
      "title": "Span Count by Service",
      "type": "table",
      "gridPos": {
        "x": 0,
        "y": 26,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "editorType": "sql",
          "format": 1,
          "queryType": "table",
          "rawSql": "SELECT service_name, count(*) AS span_count, ROUND(AVG(duration_nano)/1000000, 2) AS avg_duration_ms FROM opentelemetry_traces WHERE $__timeFilter(timestamp) GROUP BY service_name ORDER BY span_count DESC",
          "datasource": {
            "type": "info8fcc-greptimedb-datasource",
            "uid": "dfsr7wolp7awwf"
          }
        }
      ],
      "datasource": {
        "type": "info8fcc-greptimedb-datasource",
        "uid": "dfsr7wolp7awwf"
      }
    },
    {
      "title": "Span Duration Distribution",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 26,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "editorType": "sql",
          "format": 0,
          "queryType": "timeseries",
          "rawSql": "SELECT date_bin('$__interval', timestamp) AS time, service_name AS metric, ROUND(AVG(duration_nano)/1000000, 2) AS avg_duration_ms FROM opentelemetry_traces WHERE $__timeFilter(timestamp) GROUP BY time, metric ORDER BY time",
          "datasource": {
            "type": "info8fcc-greptimedb-datasource",
            "uid": "dfsr7wolp7awwf"
          }
        }
